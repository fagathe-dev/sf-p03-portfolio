{# templates/emails/contact_confirmation.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Votre message a bien été reçu</title>
  <style>
    body { margin: 0; padding: 0; background-color: #fafaf7; font-family: 'Inter', Arial, sans-serif; color: #1c1c1a; }
    .wrapper { max-width: 560px; margin: 2rem auto; background-color: #ffffff; border: 1px solid #d4d4cc; }
    .header { padding: 1.5rem 2rem; border-bottom: 1px solid #d4d4cc; }
    .logo { font-family: 'Courier New', monospace; font-size: 1.25rem; font-weight: 700; color: #1c1c1a; text-decoration: none; }
    .logo-dot { color: #4a5240; }
    .body { padding: 2rem; }
    h1 { font-size: 1.125rem; font-weight: 700; margin: 0 0 1rem; }
    p { margin: 0 0 0.875rem; font-size: 0.9375rem; line-height: 1.65; color: #1c1c1a; }
    .recap { margin: 1.5rem 0; background-color: #f5f5f0; border: 1px solid #d4d4cc; padding: 1rem 1.25rem; }
    .recap-row { display: flex; gap: 0.75rem; padding: 0.4rem 0; border-bottom: 1px solid #e4e4dc; font-size: 0.875rem; }
    .recap-row:last-child { border-bottom: none; }
    .recap-label { font-family: 'Courier New', monospace; font-weight: 600; min-width: 9rem; color: #5c5c57; font-size: 0.75rem; text-transform: uppercase; }
    .recap-value { color: #1c1c1a; }
    .footer { padding: 1rem 2rem; border-top: 1px solid #d4d4cc; font-size: 0.75rem; color: #5c5c57; font-family: 'Courier New', monospace; }
  </style>
</head>
<body>
  <div class="wrapper">

    <div class="header">
      <img
        src="{{ absolute_url(asset('images/logo.webp')) }}"
        alt="Logo site web portefolio de Frédérick AGATHE"
        style="width: auto; height: 28px; display: block; margin: 0 auto;"
      />
    </div>

    <div class="body">
      <h1>Votre message a bien été reçu, {{ dto.fullName }} !</h1>

      <p>
        Merci de m'avoir contacté. Je prends connaissance de votre message
        et vous répondrai dans les meilleurs délais.
      </p>

      <p>Voici un récapitulatif de ce que vous m'avez envoyé :</p>

      <div class="recap">
        <div class="recap-row">
          <span class="recap-label">Nom</span>
          <span class="recap-value">{{ dto.fullName }}</span>
        </div>
        <div class="recap-row">
          <span class="recap-label">Email</span>
          <span class="recap-value">{{ dto.email }}</span>
        </div>
        {% if dto.phone %}
        <div class="recap-row">
          <span class="recap-label">Téléphone</span>
          <span class="recap-value">{{ dto.phone }}</span>
        </div>
        {% endif %}
        <div class="recap-row">
          <span class="recap-label">Motif</span>
          <span class="recap-value">{{ dto.subject }}</span>
        </div>
        {% if dto.linkProposition %}
        <div class="recap-row">
          <span class="recap-label">Lien</span>
          <span class="recap-value">{{ dto.linkProposition }}</span>
        </div>
        {% endif %}
        <div class="recap-row">
          <span class="recap-label">Message</span>
          <span class="recap-value">{{ dto.message|nl2br }}</span>
        </div>
      </div>

      <p>À bientôt,<br><strong>{{ ownerName }}</strong></p>
    </div>

    <div class="footer">
      Cet email est envoyé automatiquement depuis le formulaire de contact de mon portfolio.
      Vous ne pouvez pas y répondre directement — utilisez le bouton "Répondre" de votre messagerie.
    </div>

  </div>
</body>
</html>
