{# templates/emails/contact_notification.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nouveau message — {{ subjectLabel }}</title>
  <style>
    body { margin: 0; padding: 0; background-color: #fafaf7; font-family: 'Inter', Arial, sans-serif; color: #1c1c1a; }
    .wrapper { max-width: 560px; margin: 2rem auto; background-color: #ffffff; border: 1px solid #d4d4cc; }
    .header { padding: 1rem 2rem; background-color: #4a5240; }
    .header-title { font-family: 'Courier New', monospace; font-size: 0.75rem; font-weight: 700; color: #ffffff; text-transform: uppercase; letter-spacing: 0.08em; margin: 0; }
    .badge { display: inline-block; margin-top: 0.375rem; padding: 0.2rem 0.6rem; background-color: #e8ebe3; color: #4a5240; font-family: 'Courier New', monospace; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; }
    .body { padding: 2rem; }
    .field { margin-bottom: 1.25rem; }
    .field-label { font-family: 'Courier New', monospace; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #5c5c57; margin-bottom: 0.25rem; }
    .field-value { font-size: 0.9375rem; line-height: 1.6; color: #1c1c1a; padding: 0.625rem 0.75rem; background-color: #f5f5f0; border: 1px solid #d4d4cc; }
    .field-value a { color: #4a5240; }
    .message-value { white-space: pre-wrap; }
    .footer { padding: 1rem 2rem; border-top: 1px solid #d4d4cc; font-size: 0.75rem; color: #5c5c57; font-family: 'Courier New', monospace; }
  </style>
</head>
<body>
  <div class="wrapper">

    <div class="header">
      <p class="header-title">Nouveau message portfolio</p>
      <span class="badge">{{ subjectLabel }}</span>
    </div>

    <div class="body">

      <div class="field">
        <div class="field-label">Expéditeur</div>
        <div class="field-value">{{ dto.fullName }} &lt;{{ dto.email }}&gt;</div>
      </div>

      {% if dto.phone %}
      <div class="field">
        <div class="field-label">Téléphone</div>
        <div class="field-value">{{ dto.phone }}</div>
      </div>
      {% endif %}

      <div class="field">
        <div class="field-label">Motif</div>
        <div class="field-value">{{ subjectLabel }}</div>
      </div>

      {% if dto.linkProposition %}
      <div class="field">
        <div class="field-label">Lien de l'offre / du projet</div>
        <div class="field-value">
          <a href="{{ dto.linkProposition }}">{{ dto.linkProposition }}</a>
        </div>
      </div>
      {% endif %}

      <div class="field">
        <div class="field-label">Message</div>
        <div class="field-value message-value">{{ dto.message }}</div>
      </div>

    </div>

    <div class="footer">
      Répondre directement à : {{ dto.email }} — envoyé le {{ "now"|date("d/m/Y à H:i") }}
    </div>

  </div>
</body>
</html>
